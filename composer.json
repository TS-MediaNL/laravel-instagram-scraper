{
    "name": "tsmedia/laravel-instagram-scraper",
    "description": "Laravel package voor het scrapen van publieke Instagram-profielen (eigen namespace, Guzzle 7 / PSR-18).",
    "version": "0.2.0",
    "type": "library",
    "keywords": [
        "laravel",
        "instagram",
        "scraper",
        "guzzle"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "TS-Media",
            "homepage": "https://groteverbouwing.nl"
        }
    ],
    "require": {
        "php": "^8.2",
        "ext-json": "*",
        "ext-curl": "*",
        "guzzlehttp/guzzle": "^7.8",
        "guzzlehttp/psr7": "^2.7",
        "illuminate/contracts": "^11.0|^12.0",
        "illuminate/support": "^11.0|^12.0",
        "psr/http-client": "^1.0.1",
        "psr/http-factory": "^1.0.2",
        "psr/simple-cache": ">=1.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "TsMedia\\LaravelInstagramScraper\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "TsMedia\\LaravelInstagramScraper\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "TsMedia\\LaravelInstagramScraper\\LaravelInstagramScraperServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
